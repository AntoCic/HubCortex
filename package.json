{
  "name": "hubcortex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "predeploy": "vue-tsc -b && node ./script/predeploy.js",
    "builddeploy": "vite build",
    "postdeploy": "node ./script/postdeploy.js",
    "build-d": "node ./script/predeploy.js && vite build && firebase deploy --only hosting,firestore,functions,storage && node ./script/postdeploy.js",
    "start": "node ./.firebase-emulators/emu.js start",
    "emu:start": "node ./.firebase-emulators/emu.js start",
    "emu:help": "node ./.firebase-emulators/emu.js help",
    "emu:save": "node ./.firebase-emulators/emu.js save"
  },
  "dependencies": {
    "@tiptap/extension-code-block": "^3.4.1",
    "@tiptap/extension-link": "^3.4.1",
    "@tiptap/extension-placeholder": "^3.4.1",
    "@tiptap/pm": "^3.4.1",
    "@tiptap/starter-kit": "^3.4.1",
    "@tiptap/vue-3": "^3.4.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "bootstrap": "^5.3.7",
    "firebase": "^12.0.0",
    "sass": "^1.89.2",
    "vue": "^3.5.24",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "@types/bootstrap": "^5.2.10",
    "vite-plugin-pwa": "^1.0.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4"
  }
}