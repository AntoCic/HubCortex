rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasPermission(requiredPerm) {
      return isSignedIn() && (
        (
          request.auth.token.permissions != null &&
          request.auth.token.permissions is list &&
          requiredPerm in request.auth.token.permissions
        )
        ||
        (
          exists(userDocPath()) &&
          get(userDocPath()).data.permissions is list &&
          requiredPerm in get(userDocPath()).data.permissions
        )
      );
    }

    function isAdmin() {
      return hasPermission('ADMIN') || hasPermission('SUPERADMIN');
    }

    function isSuperAdmin() {
      return hasPermission('SUPERADMIN');
    }

    function hasProjectWritePermission() {
      return hasPermission('PROJECT_WRITE') || hasPermission('MANAGE_PROJECT') || isAdmin();
    }

    function hasProjectReadPermission() {
      return hasProjectWritePermission() || hasPermission('PROJECT_READ');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if (isOwner(userId) && !('permissions' in request.resource.data)) || isAdmin();

      allow update: if (
        isOwner(userId) &&
        !request.resource.data.diff(resource.data).changedKeys().hasAny(['permissions'])
      ) || isAdmin();

      allow delete: if isOwner(userId) || isSuperAdmin();

      match /settings/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /notes/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /cmd/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /public_users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /appConfig/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /agentPrompts/{id} {
      allow read: if isSignedIn();
      allow write: if hasPermission('AI');
    }

    match /projects/{id} {
      allow read: if isSignedIn() && hasProjectReadPermission();
      allow write: if isSignedIn() && hasProjectWritePermission();
    }

    match /projectTasks/{id} {
      allow read: if isSignedIn() && hasProjectReadPermission();
      allow write: if isSignedIn() && hasProjectWritePermission();
    }

    match /tags/{id} {
      allow read, write: if isSignedIn();
    }

    match /projectMessages/{id} {
      allow read: if isSignedIn() && hasProjectReadPermission();
      allow write: if isSignedIn() && hasProjectWritePermission();
    }

    match /projectNotificationPreferences/{id} {
      allow read: if isSignedIn() && hasProjectReadPermission() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      allow create: if isSignedIn() && hasProjectReadPermission() && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );

      allow update: if isSignedIn() && hasProjectReadPermission() && (
        (
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == resource.data.userId
        ) || isAdmin()
      );

      allow delete: if isSignedIn() && hasProjectReadPermission() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

  }
}
