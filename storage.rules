rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function hasPermission(requiredPerm) {
      return isSignedIn() && (
        (
          request.auth.token.permissions != null &&
          request.auth.token.permissions is list &&
          requiredPerm in request.auth.token.permissions
        )
        ||
        (
          firestore.exists(userDocPath()) &&
          firestore.get(userDocPath()).data.permissions is list &&
          requiredPerm in firestore.get(userDocPath()).data.permissions
        )
      );
    }

    function isAdmin() {
      return hasPermission('ADMIN') || hasPermission('SUPERADMIN');
    }

    function isValidUpload(maxMb, contentType) {
      return request.resource != null
        && request.resource.size < maxMb * 1024 * 1024
        && (
          contentType == null ||
          (request.resource.contentType != null && request.resource.contentType.matches(contentType))
        );
    }

    match /public/projects/{projectId}/{path=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidUpload(25, null);
      allow delete: if isSignedIn();
    }

    match /public/{path=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidUpload(50, null);
      allow delete: if isAdmin();
    }

    match /user/{userId}/{path=**} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId && isValidUpload(20, null);
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /public/user/{userId}/{path=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId && isValidUpload(20, null);
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
